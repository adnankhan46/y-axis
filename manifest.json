{
  "manifest_version": 3,
  "name": "Y-Axis : Natigate through long Chats",
  "version": "2.0",
  "description": "Sidebar navigation and export for Claude, ChatGPT, Gemini, and DeepSeek.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://chat.deepseek.com/*"
      ],
      "js": [
        "config/config.js",
        "content.js",
        "onboarding.js"
      ],
      "css": [
        "styles.css",
        "onboarding.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Y-Axis : Natigate through long Chats",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "public/images/*",
        "public/fonts/*"
      ],
      "matches": [
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://chat.deepseek.com/*"
      ]
    }
  ]
}